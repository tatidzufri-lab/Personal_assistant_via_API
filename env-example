# Пример файла конфигурации .env
# Скопируйте этот файл в .env и заполните своими значениями

# Токен Telegram-бота — получить у @BotFather в Telegram
TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Ключ OpenAI API — получить на https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-ваш_ключ_здесь

# Модель OpenAI (по умолчанию gpt-4o)
OPENAI_MODEL=gpt-4o

# Учётные данные GigaChat (опционально — для переключения модели по кнопке)
# Получить на https://developers.sber.ru/gigachat
GIGACHAT_CREDENTIALS=ваш_ключ_gigachat_здесь

# Модель GigaChat (по умолчанию GigaChat-2-Max)
GIGACHAT_MODEL=GigaChat-2-Max
